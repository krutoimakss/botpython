@router.message(Command("newword"), F.chat.type.in_({"group", "supergroup"}))
async def cmd_newword(message: Message, bot: Bot):
    if not await is_chat_admin(bot, message.chat.id, message.from_user.id):
        await message.reply(texts.NOT_ADMIN_TEXT)
        return
    parts = message.text.split(maxsplit=1)
    if len(parts) < 2 or not parts[1].strip():
        await message.reply("⚠️ Использование: /newword слово")
        return
    word = parts[1].strip()
    await db.add_banned_word(message.chat.id, word)
    await message.reply(texts.WORD_ADDED_TEXT.format(word=word))


@router.message(Command("newlimit"), F.chat.type.in_({"group", "supergroup"}))
async def cmd_newlimit(message: Message, bot: Bot):
    if not await is_chat_admin(bot, message.chat.id, message.from_user.id):
        await message.reply(texts.NOT_ADMIN_TEXT)
        return
    parts = message.text.split(maxsplit=1)
    if len(parts) < 2 or not parts[1].strip().isdigit():
        await message.reply("⚠️ Использование: /newlimit число")
        return
    limit = int(parts[1].strip())
    await db.set_emoji_limit(message.chat.id, limit)
    await message.reply(texts.LIMIT_SET_TEXT.format(limit=limit))


@router.message(SettingsStates.waiting_nsfw_toggle, F.chat.type.in_({"group", "supergroup"}))
async def process_nsfw_toggle(message: Message, state: FSMContext, bot: Bot):
    if not await is_chat_admin(bot, message.chat.id, message.from_user.id):
        return
    value = message.text.strip().lower()
    if value not in ("on", "off"):
        await message.reply(texts.INVALID_ON_OFF_TEXT)
        return
    await db.set_nsfw_allowed(message.chat.id, value == "on")
    await state.clear()
    await message.reply(f"✅ 18+ контент теперь: {value}")


