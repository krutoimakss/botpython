@router.message(Command("promote"), F.chat.type.in_({"group", "supergroup"}))
async def cmd_promote(message: Message, bot: Bot):
    """Назначить администратором пользователя, на сообщение которого ответили."""
    if not await is_chat_admin(bot, message.chat.id, message.from_user.id):
        await message.reply(texts.NOT_ADMIN_TEXT)
        return
    if not message.reply_to_message:
        await message.reply("⚠️ Ответьте командой /promote на сообщение пользователя.")
        return
    target = message.reply_to_message.from_user
    try:
        await bot.promote_chat_member(
            chat_id=message.chat.id,
            user_id=target.id,
            can_delete_messages=True,
            can_restrict_members=True,
            can_invite_users=True,
            can_pin_messages=True,
            can_manage_chat=True,
        )
        await message.reply(f"✅ {target.full_name} назначен(а) администратором.")
    except Exception as e:
        await message.reply(f"⚠️ Не удалось назначить администратора: {e}")
