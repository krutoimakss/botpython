from aiogram import Router, F, Bot
from aiogram.filters import Command
from aiogram.types import Message, CallbackQuery
from aiogram.fsm.context import FSMContext

import texts
import database as db
from keyboards import main_menu_keyboard, back_keyboard
from states import SettingsStates
from utils import is_chat_admin

router = Router(name="group_menu")


@router.message(Command("menu"), F.chat.type.in_({"group", "supergroup"}))
async def cmd_menu(message: Message, bot: Bot):
    if not await is_chat_admin(bot, message.chat.id, message.from_user.id):
        await message.reply(texts.NOT_ADMIN_TEXT)
        return
    await message.answer(texts.OWNER_DM_TEXT, reply_markup=main_menu_keyboard())


@router.callback_query(F.data == "menu_back")
async def cb_back(call: CallbackQuery):
    await call.answer()
    await call.message.edit_text(texts.OWNER_DM_TEXT, reply_markup=main_menu_keyboard())


@router.callback_query(F.data == "menu_words")
async def cb_words(call: CallbackQuery):
    await call.answer()
    words = await db.get_banned_words(call.message.chat.id)
    text = texts.MENU_BANNED_WORDS_TEXT.format(
        count=len(words),
        words=", ".join(words) if words else "—",
    )
    await call.message.edit_text(text, reply_markup=back_keyboard())


@router.callback_query(F.data == "menu_emoji")
async def cb_emoji(call: CallbackQuery):
    await call.answer()
    settings = await db.get_chat_settings(call.message.chat.id)
    text = texts.MENU_EMOJI_LIMIT_TEXT.format(limit=settings["emoji_limit"])
    await call.message.edit_text(text, reply_markup=back_keyboard())


@router.callback_query(F.data == "menu_nsfw")
async def cb_nsfw(call: CallbackQuery, state: FSMContext):
    await call.answer()
    settings = await db.get_chat_settings(call.message.chat.id)
    state_txt = "on" if settings["nsfw_allowed"] else "off"
    text = texts.MENU_NSFW_TEXT.format(state=state_txt)
    await call.message.edit_text(text, reply_markup=back_keyboard())
    await state.update_data(target_chat_id=call.message.chat.id)
    await state.set_state(SettingsStates.waiting_nsfw_toggle)


